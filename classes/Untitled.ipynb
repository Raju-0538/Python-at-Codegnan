   "source": [
    "a = input()\n",
    "sum = 0\n",
    "for i in range(len(a)):\n",
    "    if a[i].isdigit():\n",
    "        ele = int(a[i])\n",
    "        sum += ele\n",
    "print(sum)"
   ]
