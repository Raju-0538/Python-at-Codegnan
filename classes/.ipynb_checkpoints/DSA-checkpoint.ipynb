   "source": [
    "n = int(input())\n",
    "count = 0\n",
    "while(n>0):\n",
    "    if n%2 == 0:\n",
    "        n /= 2\n",
    "        count += 1\n",
    "    else:\n",
    "        n -= 1\n",
    "        count += 1\n",
    "print(count)"
   ]
